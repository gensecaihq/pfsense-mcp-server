# pfSense MCP Server Configuration

# pfSense Connection
PFSENSE_URL=https://your-pfsense.local
# Options: CE_2_8_0, PLUS_24_11
PFSENSE_VERSION=CE_2_8_0

# Authentication
# Options: api_key, basic, jwt
AUTH_METHOD=api_key
PFSENSE_API_KEY=your-api-key-here
# For basic/jwt auth, uncomment:
# PFSENSE_USERNAME=admin
# PFSENSE_PASSWORD=your-password

# SSL
VERIFY_SSL=true

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=3000

# MCP Bearer Token Auth (for HTTP transport - strongly recommended)
MCP_API_KEY=your-bearer-token-here

# Optional
ENABLE_HATEOAS=false
LOG_LEVEL=INFO
