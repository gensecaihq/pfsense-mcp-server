# pfSense MCP Server Configuration

# pfSense Connection
PFSENSE_URL=https://your-pfsense.local
# Options: CE_2_8_0, CE_2_8_1, CE_26_03, PLUS_24_11, PLUS_25_11
PFSENSE_VERSION=CE_2_8_0

# Authentication
# Options: api_key, basic, jwt
AUTH_METHOD=api_key
PFSENSE_API_KEY=your-api-key-here
# For basic/jwt auth, uncomment:
# PFSENSE_USERNAME=admin
# PFSENSE_PASSWORD=your-password

# SSL
VERIFY_SSL=true

# MCP Server
# Default 127.0.0.1 per MCP spec (use 0.0.0.0 for remote access)
MCP_HOST=127.0.0.1
MCP_PORT=3000

# MCP Bearer Token Auth (required for HTTP transport)
# IMPORTANT: Generate a unique token: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=CHANGE-ME-generate-a-secure-token

# Allowed Origins for HTTP transport (comma-separated, MCP spec requirement)
# Default: http://localhost,https://localhost,http://127.0.0.1,https://127.0.0.1
# MCP_ALLOWED_ORIGINS=https://your-app.example.com

# Optional
ENABLE_HATEOAS=false
LOG_LEVEL=INFO
# API request timeout in seconds (increase for slow hardware or large rulesets)
API_TIMEOUT=30

# Read-only mode: only expose search/get/find tools (MCP least-privilege best practice)
# MCP_READ_ONLY=true

# Guardrails — Defense-in-depth for destructive operations
# Audit log file (JSON lines format). Leave empty to disable file logging.
# MCP_AUDIT_LOG=/var/log/pfsense-mcp-audit.jsonl
# Rate limits (max operations per window)
# MCP_RATE_LIMIT_DELETE=10    # Deletes per 60s
# MCP_RATE_LIMIT_CREATE=20    # Creates per 60s
# MCP_RATE_LIMIT_CRITICAL=2   # Critical ops (reboot/halt) per 300s
# Tool allowlist (comma-separated). If set, only listed tools can execute destructive actions.
# MCP_ALLOWED_TOOLS=search_firewall_rules,create_firewall_rule_advanced,delete_firewall_rule
# Rollback buffer size (in-memory, for undo tracking)
# MCP_ROLLBACK_BUFFER=50
