# pfSense MCP Server Configuration

# pfSense Connection
PFSENSE_URL=https://your-pfsense.local
# Options: CE_2_8_0, CE_2_8_1, CE_26_03, PLUS_24_11, PLUS_25_11
PFSENSE_VERSION=CE_2_8_0

# Authentication
# Options: api_key, basic, jwt
AUTH_METHOD=api_key
PFSENSE_API_KEY=your-api-key-here
# For basic/jwt auth, uncomment:
# PFSENSE_USERNAME=admin
# PFSENSE_PASSWORD=your-password

# SSL
VERIFY_SSL=true

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=3000

# MCP Bearer Token Auth (required for HTTP transport)
# IMPORTANT: Generate a unique token: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=CHANGE-ME-generate-a-secure-token

# Optional
ENABLE_HATEOAS=false
LOG_LEVEL=INFO
# API request timeout in seconds (increase for slow hardware or large rulesets)
API_TIMEOUT=30
