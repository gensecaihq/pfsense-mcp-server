# pfSense MCP Server Configuration

# pfSense Connection
PFSENSE_URL=https://your-pfsense.local
PFSENSE_VERSION=CE_2_8_0            # Options: CE_2_8_0, PLUS_24_11

# Authentication
AUTH_METHOD=api_key                  # Options: api_key, basic, jwt
PFSENSE_API_KEY=your-api-key-here
# PFSENSE_USERNAME=admin             # For basic auth
# PFSENSE_PASSWORD=your-password     # For basic auth

# SSL
VERIFY_SSL=true

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=3000

# MCP Bearer Token Auth (for HTTP transport - strongly recommended)
MCP_API_KEY=your-bearer-token-here

# Optional
ENABLE_HATEOAS=false
LOG_LEVEL=INFO
